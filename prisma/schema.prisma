generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  draft
  active
}

enum AuthorGroup {
  nachman
  nossen
  anash
  set
  other
}

enum StockReason {
  initial
  manual_adjustment
  order
  return
  correction
}

enum AdminRole {
  admin
  staff
}

enum OrderStatus {
  pending
  paid
  shipped
  delivered
  cancelled
}

enum PaymentPref {
  contact_me
  invoice
  phone
  in_person
}

enum OrderEventKind {
  placed
  paid
  shipped
  delivered
  cancelled
  note
}

model Product {
  id              String        @id @default(cuid())
  handle          String        @unique
  title           String
  titleHe         String?
  author          String?
  series          String?
  authorGroup     AuthorGroup   @default(other)
  seforGroup      String?
  descriptionHtml String?
  status          ProductStatus @default(draft)
  voiceCode       String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  variants Variant[]
  images   ProductImage[]

  @@index([status])
  @@index([authorGroup])
  @@index([seforGroup])
}

model Variant {
  id              String   @id @default(cuid())
  productId       String
  name            String
  sku             String   @unique
  barcode         String?
  priceCents      Int
  compareAtCents  Int?
  weightGrams     Int?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory  InventoryLevel?
  movements  StockMovement[]
  orderLines OrderLine[]

  @@index([productId])
}

model ProductImage {
  id       String  @id @default(cuid())
  productId String
  url      String
  altText  String?
  position Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

model InventoryLevel {
  variantId     String @id
  onHand        Int    @default(0)
  reserved      Int    @default(0)
  reorderPoint  Int?
  updatedAt     DateTime @updatedAt

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id        String      @id @default(cuid())
  variantId String
  delta     Int
  reason    StockReason
  note      String?
  actor     String
  createdAt DateTime    @default(now())

  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, createdAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(admin)
  createdAt    DateTime  @default(now())
}

model Order {
  id                String       @id @default(cuid())
  orderNo           String       @unique
  status            OrderStatus  @default(pending)
  paymentPref       PaymentPref
  customerEmail     String
  customerName      String
  customerPhone     String?
  shipStreet        String
  shipStreet2       String?
  shipCity          String
  shipState         String
  shipZip           String
  shipCountry       String       @default("United States")
  customerNote      String?
  internalNote      String?
  subtotalCents     Int
  shippingCents     Int          @default(0)
  totalCents        Int
  trackingCarrier   String?
  trackingNumber    String?
  paymentRecordedAs String?
  placedAt          DateTime     @default(now())
  paidAt            DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  lines  OrderLine[]
  events OrderEvent[]

  @@index([status])
  @@index([customerEmail])
  @@index([placedAt])
}

model OrderLine {
  id                  String @id @default(cuid())
  orderId             String
  variantId           String
  quantity            Int
  unitPriceCents      Int
  lineTotalCents      Int
  snapshotTitle       String
  snapshotSku         String
  snapshotHandle      String
  snapshotVariantName String
  snapshotImageUrl    String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([variantId])
}

model OrderEvent {
  id        String         @id @default(cuid())
  orderId   String
  kind      OrderEventKind
  actor     String
  body      String?
  createdAt DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
