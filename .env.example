# Postgres connection string used by Prisma
DATABASE_URL="postgres://user:pass@host:5432/dbname"

# 32+ char random string; signs the admin session JWT
SESSION_SECRET="replace-with-32-plus-char-random-string"

# Credentials used by `npm run seed:admin` to create the first admin user
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
